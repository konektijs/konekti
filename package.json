{
  "name": "konekti",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.26.4",
    "@babel/core": "^7.26.10",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@babel/preset-typescript": "^7.27.1",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' --if-present run build",
    "typecheck": "tsc -p tsconfig.tools.json --noEmit && pnpm -r --filter './packages/*' --if-present run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm -r --if-present run lint",
    "verify:release-candidate": "node tooling/release/verify-release-candidate.mjs"
  }
}
