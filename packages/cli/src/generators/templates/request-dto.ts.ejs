import { ensureMetadataSymbol } from '@fluojs/core';
import { IsString, MinLength } from '@fluojs/validation';
import { FromBody } from '@fluojs/http';

ensureMetadataSymbol();

export class <%- pascal %> {
  @FromBody('<%- bodyField %>')
  @IsString()
  @MinLength(1, { message: '<%- bodyField %> is required' })
  <%- bodyField %> = '';
}
