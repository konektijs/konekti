import { ensureMetadataSymbol } from '@fluojs/core';
<% } %>
import { Controller, Get } from '@fluojs/http';

<% if (hasService) { %>
import { <%- service %> } from './<%- kebab %>.service';
<% } %>

ensureMetadataSymbol();

@Controller('/<%- kebab %>')
