{
  "name": "@konekti/websocket",
  "description": "Decorator-based WebSocket gateway authoring core for Konekti, with explicit Node ws binding on the node subpath.",
  "keywords": [
    "konekti",
    "websocket",
    "ws",
    "gateway",
    "realtime",
    "upgrade"
  ],
  "version": "0.0.0",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/konektijs/konekti.git",
    "directory": "packages/websocket"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "node": [
        "./dist/node.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node ../../tooling/scripts/clean-dist.mjs",
    "build": "pnpm exec babel src --extensions .ts --ignore 'src/**/*.test.ts' --out-dir dist --config-file ../../tooling/babel/babel.config.cjs && pnpm exec tsc -p tsconfig.build.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@konekti/core": "workspace:*",
    "@konekti/di": "workspace:*",
    "@konekti/http": "workspace:*",
    "@konekti/runtime": "workspace:*",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@konekti/platform-express": "workspace:*",
    "@konekti/platform-fastify": "workspace:*",
    "@types/ws": "^8.18.1"
  }
}
