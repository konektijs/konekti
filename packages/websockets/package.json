{
  "name": "@fluojs/websockets",
  "description": "Decorator-based WebSocket gateway authoring core for Fluo, with explicit Node, Bun, Deno, and Cloudflare Workers raw websocket bindings on dedicated subpaths.",
  "keywords": [
    "fluo",
    "websocket",
    "ws",
    "gateway",
    "realtime",
    "upgrade"
  ],
  "version": "0.0.0",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fluojs/fluo.git",
    "directory": "packages/websockets"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bun": {
      "types": "./dist/bun.d.ts",
      "import": "./dist/bun.js"
    },
    "./deno": {
      "types": "./dist/deno.d.ts",
      "import": "./dist/deno.js"
    },
    "./cloudflare-workers": {
      "types": "./dist/cloudflare-workers.d.ts",
      "import": "./dist/cloudflare-workers.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "bun": [
        "./dist/bun.d.ts"
      ],
      "deno": [
        "./dist/deno.d.ts"
      ],
      "cloudflare-workers": [
        "./dist/cloudflare-workers.d.ts"
      ],
      "node": [
        "./dist/node.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node ../../tooling/scripts/clean-dist.mjs",
    "build": "pnpm exec babel src --extensions .ts --ignore 'src/**/*.test.ts' --out-dir dist --config-file ../../tooling/babel/babel.config.cjs && pnpm exec tsc -p tsconfig.build.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm exec vitest run -c vitest.config.ts",
    "test:watch": "pnpm exec vitest -c vitest.config.ts"
  },
  "dependencies": {
    "@fluojs/core": "workspace:^",
    "@fluojs/di": "workspace:^",
    "@fluojs/http": "workspace:^",
    "@fluojs/runtime": "workspace:^",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@fluojs/platform-bun": "workspace:^",
    "@fluojs/platform-express": "workspace:^",
    "@fluojs/platform-fastify": "workspace:^",
    "@types/ws": "^8.18.1",
    "vitest": "^3.2.4"
  }
}
