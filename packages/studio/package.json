{
  "name": "@fluojs/studio",
  "description": "File-first diagnostics viewer for Fluo runtime platform snapshot and timing JSON exports.",
  "keywords": [
    "fluo",
    "studio",
    "diagnostics",
    "viewer",
    "module-graph",
    "devtools"
  ],
  "version": "0.0.0",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fluojs/fluo.git",
    "directory": "packages/studio"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm exec vite build",
    "dev": "pnpm exec vite",
    "preview": "pnpm exec vite preview",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm exec vitest run -c vitest.config.ts",
    "test:watch": "pnpm exec vitest -c vitest.config.ts"
  },
  "dependencies": {
    "@fluojs/runtime": "workspace:*"
  },
  "devDependencies": {
    "@fluojs-internal/tooling-vite": "workspace:*",
    "vitest": "^3.2.4"
  }
}
